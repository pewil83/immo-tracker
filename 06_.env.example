# Immobilien-Tracker Configuration

# Flask Settings
FLASK_ENV=production
DEBUG=False

# Database
DB_PATH=immobilien.db

# Domain (für HTTPS/Nginx)
DOMAIN=immobilien-tracker.at
DOMAIN_WWW=www.immobilien-tracker.at

# API Settings
API_HOST=0.0.0.0
API_PORT=5000

# Scraper Settings
SCRAPE_REGION=wien
SCRAPE_MAX_PRICE=25000000
SCRAPE_INTERVAL=daily

# Google API (optional, für zukünftige Features)
GOOGLE_API_KEY=
GOOGLE_STREETVIEW_ENABLED=false

# Backup Settings
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=/tmp/immobilien.log
